4.5063, -208.10579, -251.96709, 4.5717, -210.73549, -248.54639, 4.5717, -211.66269, -247.8263, 4.506, -209.0329, -251.2372, 4.5063, -208.10579, -173.165, 4.5793, -216.62439, -178.1866, 4.4989, -215.44429, -177.4421, 4.5794, -218.0741, -173.165, 4.5793, -216.62439, -174.0847, 4.4988, -214.0508, -178.1866, 4.4989, -215.44429, -1.9755, 0, -45.7472, -4.5203, -0.018099999, -48.7309, -1.8052, 0, -48.3938, -1.9755, 0, -45.7472, -4.7051997, -0.024899999, -45.848297, -4.5203, -0.018099999, -48.7309, -207.34749, 4.5794, -219.1473, -211.0698, 4.5056, -216.2872, -211.245, 4.5793, -219.0125, -207.34749, 4.5794, -219.1473, -207.25989, 4.5046997, -216.42209, -211.0698, 4.5056, -216.2872, -2.0047, 0, -43.0444, -4.7051997, -0.024899999, -45.848297, -1.9755, 0, -45.7472, -2.0047, 0, -43.0444, -4.7344, -0.0274, -43.0556, -4.7051997, -0.024899999, -45.848297, -146.3738, 4.5794, -193.62529, -151.6581, 4.5122, -196.1371, -149.4587, 4.5793, -197.7554, -146.3738, 4.5794, -193.62529, -148.5439, 4.5113997, -191.9677, -151.6581, 4.5122, -196.1371, -203.38179, 4.5793, -219.26529, -207.25989, 4.5046997, -216.42209, -207.34749, 4.5794, -219.1473, -203.38179, 4.5793, -219.26529, -203.2602, 4.505, -216.5401, -207.25989, 4.5046997, -216.42209, -85.842896, 4.5794, -164.9341, -90.820595, 4.4989, -164.1138, -89.7502, 4.5793, -166.61989, -85.842896, 4.5794, -164.9341, -86.947395, 4.499, -162.4393, -90.820595, 4.4989, -164.1138, -143.70729, 4.5793, -190.2033, -148.5439, 4.5113997, -191.9677, -146.3738, 4.5794, -193.62529, -143.70729, 4.5793, -190.2033, -145.8531, 4.5109, -188.5232, -148.5439, 4.5113997, -191.9677, -17.1569, 0, -116.2614, -21.7453, -0.0795, -115.7725, -20.3829, 0, -118.1382, -17.1569, 0, -116.2614, -18.4658, -0.079799995, -113.862, -21.7453, -0.0795, -115.7725, -258.5749, 4.5717, -208.72389, -261.2852, 4.5071, -205.004, -262.0637, 4.5717, -207.6169, -258.5749, 4.5717, -208.72389, -257.7428, 4.5081, -206.1222, -261.2852, 4.5071, -205.004, -82.334595, 4.5793, -163.3383, -86.947395, 4.499, 